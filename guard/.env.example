# Input-safety (Prompt Guard) service config.

# The classifier model. Default = Meta Llama Prompt Guard 2 (22M) — GATED, needs an
# approved Llama license + HF_TOKEN (set in the repo-root .env). Until the license
# clears, point this at an ungated stand-in so the service runs:
#   GUARD_MODEL_ID=protectai/deberta-v3-base-prompt-injection-v2
GUARD_MODEL_ID=meta-llama/Llama-Prompt-Guard-2-22M

# Malicious-class probability threshold to block (0..1).
GUARD_THRESHOLD=0.5

# Max characters of a single message to screen (longer is truncated before windowing).
GUARD_MAX_CHARS=8000

# HF_TOKEN is read from the repo-root .env (shared) — needed only for the gated
# Prompt Guard weights.
