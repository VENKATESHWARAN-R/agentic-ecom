# Model for the shopping agent, in Pydantic AI "provider:model" format.
# Falls back to COPILOTKIT_MODEL from the repo-root .env, then to the default below.
AGENT_MODEL=anthropic:claude-sonnet-4-6

# Provider API key — only needed if not already set in the repo-root .env.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# Where the SQLite database lives (default: backend/voltti.db).
# VOLTTI_DB_PATH=

# CORS origin of the Next.js storefront.
FRONTEND_ORIGIN=http://localhost:3000

# Shared secret for the BFF→backend identity assertion (must match the Next
# app's INTERNAL_JWT_SECRET). Falls back to the repo-root .env if unset here.
# INTERNAL_JWT_SECRET=
