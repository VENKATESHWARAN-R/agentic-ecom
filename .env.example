# CopilotKit BuiltInAgent model ("provider/model" or "provider:model").
# Examples:
# COPILOTKIT_MODEL=anthropic:claude-sonnet-4-6
# COPILOTKIT_MODEL=anthropic/claude-3.5-haiku
# COPILOTKIT_MODEL=openai/gpt-4o-mini
# COPILOTKIT_MODEL=google/gemini-2.5-flash
COPILOTKIT_MODEL=anthropic:claude-sonnet-4-6

# Set the key that matches COPILOTKIT_MODEL.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Optional. Set to true to disable CopilotKit anonymous telemetry in local/dev/demo runs.
COPILOTKIT_TELEMETRY_DISABLED=false

# Next.js defaults.
PORT=3000

# --- Agent backend (Python, backend/) ---
# AG-UI endpoint the CopilotKit runtime forwards chat to (server-side).
AGENT_URL=http://localhost:8000/agui
# Server-side base for the BFF proxy → backend REST (Slice 1b, P4). The browser
# now calls the same-origin BFF (/api/bff); it never holds the backend URL.
BACKEND_URL=http://localhost:8000
# Deprecated (browser no longer uses it); kept only as a BACKEND_URL fallback.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Shared secret for the BFF→backend identity assertion (Slice 1, P4): the Next
# server signs a short-lived JWT with it and the Python backend verifies it.
# The SAME value must reach both services. Use a strong random value in prod.
INTERNAL_JWT_SECRET=dev-voltti-internal-change-me

# --- Input-safety guard (Python, guard/; Slice 4, P3/P7) ---
# The backend screens each user message against the guard service before running
# the agent. The guard is non-mandatory: GUARD_FAIL_OPEN=true means a guard outage
# allows traffic through (logged) rather than taking chat down.
GUARD_ENABLED=true
GUARD_URL=http://localhost:8001
GUARD_FAIL_OPEN=true

# Guard model + decision threshold (read by the guard service itself). Default is
# Meta's gated Llama Prompt Guard 2 (needs an approved license + HF_TOKEN below).
GUARD_MODEL_ID=meta-llama/Llama-Prompt-Guard-2-22M
GUARD_THRESHOLD=0.5

# HuggingFace token for the gated Prompt Guard weights (guard service + Docker build).
HF_TOKEN=hf_xxxxxxxx